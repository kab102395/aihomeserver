# Optional: keep runtime data out of the repo root
DATA_DIR=./data

# Workspace root for filesystem/shell tools
WORKSPACE=./workspace

# Server port
PORT=3000

# Ollama
OLLAMA_URL=http://localhost:11434

# Recommended: SearXNG (if running locally)
# SEARCH_URL=http://localhost:8080

# Remote execution worker (optional)
# WORKER_URL=http://localhost:3031
# WORKER_TOKEN=change-me

# Optional public API protection
# API_KEY=change-me

# Execution mode preference: auto | remote | local
# EXECUTION_MODE=auto

# Optional API-backed search providers (recommended for reliability)
# You.com Search API (https://you.com/docs/api-reference/search/v1-search)
# YOU_API_KEY=
# Tavily Search API (https://docs.tavily.com/api-reference/endpoint/search)
# TAVILY_API_KEY=
# Brave Search API (https://brave.com/search/api/) — sent as X-Subscription-Token
# BRAVE_SEARCH_API_KEY=
# SerpAPI (https://serpapi.com/search-api) — consider usage limits/credits
# SERPAPI_API_KEY=
# SerpAPI guardrails (optional)
# - SERPAPI_MAX_CALLS_PER_RUN defaults to 3
# - SERPAPI_ALLOW_FALLBACK defaults to true (used only if other APIs return nothing)
# - SERPAPI_PREFERRED=1 forces SerpAPI to be considered as a primary provider (not recommended)
# SERPAPI_MAX_CALLS_PER_RUN=3
# SERPAPI_ALLOW_FALLBACK=true
# SERPAPI_PREFERRED=0
