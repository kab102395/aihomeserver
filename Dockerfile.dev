FROM rust:1-bookworm

WORKDIR /workspace

# Dev utilities for agent tools + building/running from source
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    pkg-config \
    libssl-dev \
    ripgrep \
    jq \
    && rm -rf /var/lib/apt/lists/*

# In dev we run from the bind-mounted repo, so no COPY here.
ENV DATA_DIR=/data
ENV PORT=3000
ENV WORKSPACE=/workspace

EXPOSE 3000

CMD ["cargo", "run", "--release"]

