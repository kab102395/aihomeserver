                    )
                full_path.write_text(content or "", encoding="utf-8")
                cp = self.create_checkpoint({"action": "write", "path": str(full_path), "size": len(content or "")})
                return ToolResult(
                    success=True,
                    output={"path": str(full_path), "bytes_written": len(content or "")},
